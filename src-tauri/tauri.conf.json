{
  "$schema": "https://raw.githubusercontent.com/nicogarciaZ/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Helix",
  "version": "0.2.1",
  "identifier": "com.helix.music",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ui",
    "beforeBuildCommand": "npm run build --prefix ui"
  },
  "app": {
    "windows": [
      {
        "title": "Helix",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/art/**/*"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; media-src 'self' http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "E7B2A9F0-3C4D-5E6F-8A1B-2C3D4E5F6A7B"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "Spanish", "French", "German", "PortugueseBR", "Russian", "SimpChinese", "Japanese"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
