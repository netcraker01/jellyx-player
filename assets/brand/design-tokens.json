{
  "brand": "Helix",
  "purpose": "Desktop background music player application",
  "colors": {
    "midnight": {
      "hex": "#0B0F2B",
      "rgb": "11, 15, 43",
      "use": "Primary background, desktop icon, sidebars"
    },
    "indigo": {
      "hex": "#1A1F4D",
      "rgb": "26, 31, 77",
      "use": "Secondary dark surfaces, cards, dark hover states"
    },
    "electric_cyan": {
      "hex": "#00E5FF",
      "rgb": "0, 229, 255",
      "use": "Active accent, dot on the i, action icons"
    },
    "helix_violet": {
      "hex": "#8A5CFF",
      "rgb": "138, 92, 255",
      "use": "Progress, selection, secondary active states"
    },
    "magenta_pulse": {
      "hex": "#D946FF",
      "rgb": "217, 70, 255",
      "use": "Emotional accent, visualizer, highlights"
    },
    "ice": {
      "hex": "#F2F4F8",
      "rgb": "242, 244, 248",
      "use": "Light backgrounds, soft dividers"
    },
    "white": {
      "hex": "#FFFFFF",
      "rgb": "255, 255, 255",
      "use": "Surfaces and text on dark backgrounds"
    }
  },
  "gradients": {
    "helix_primary": "linear-gradient(135deg, #00E5FF 0%, #8A5CFF 58%, #D946FF 100%)",
    "dark_surface": "linear-gradient(180deg, #0B0F2B 0%, #111642 100%)",
    "progress": "linear-gradient(90deg, #00E5FF 0%, #8A5CFF 70%, #D946FF 100%)"
  },
  "typography": {
    "logo_style": "Geometric, tech-forward, rounded, with an angular X and a cyan dot on the i",
    "ui_primary": "Inter / SF Pro / Segoe UI Variable",
    "ui_fallback": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "scale_px": {
      "display": 40,
      "title": 24,
      "section": 18,
      "body": 14,
      "caption": 12
    }
  },
  "radii_px": {
    "app_icon": 128,
    "cards": 20,
    "buttons": 12,
    "inputs": 10,
    "small": 8
  },
  "spacing_px": {
    "xs": 4,
    "s": 8,
    "m": 16,
    "l": 24,
    "xl": 32,
    "xxl": 48
  },
  "iconography": {
    "stroke": "2 px",
    "corners": "rounded",
    "style": "linear and clean",
    "metaphors": [
      "play",
      "pause",
      "waveform",
      "shuffle",
      "queue",
      "repeat"
    ]
  },
  "ui": {
    "dark_player": {
      "background": "#0B0F2B",
      "surface": "#1A1F4D",
      "primary_text": "#FFFFFF",
      "secondary_text": "#B8C0D9",
      "accent": "#00E5FF"
    },
    "light_player": {
      "background": "#F2F4F8",
      "surface": "#FFFFFF",
      "primary_text": "#0B0F2B",
      "secondary_text": "#5F668A",
      "accent": "#8A5CFF"
    }
  }
}
